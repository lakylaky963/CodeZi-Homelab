# ==========================================
# DEVELOPMENT ENVIRONMENT
# ==========================================
PORT=8080
NODE_ENV=development

# Local MongoDB (for development)
# MONGO_URI=mongodb://localhost:27017/codezi

# MongoDB Atlas Cloud (for production)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/codezi?retryWrites=true&w=majority
# NOTE: MONGODB_URI is also accepted for compatibility, but MONGO_URI is preferred.

# Allowed client URLs (comma-separated, no spaces)
CLIENT_URL=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174,https://codezi.vercel.app

# ==========================================
# PRODUCTION ENVIRONMENT (GCP Cloud Run)
# ==========================================
# Same variables as above, but set in GCP Console:
#
# gcloud run deploy poker-server \
#   --set-env-vars "NODE_ENV=production,PORT=8080,MONGODB_URI=...,CLIENT_URL=https://codezi.vercel.app"
#
# ==========================================
